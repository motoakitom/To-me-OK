---
const frontmatter = {
  title: "About Me",
  description: "Learn more about me and my work"
};
---

<main class="container mx-auto px-4 py-12">
  <section>
    <h1 class="text-4xl font-bold mb-8">About Me</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <img src="/images/profile.jpg" alt="Profile" class="rounded-lg w-full h-96 object-cover" />
      </div>
      <div>
        <h2 class="text-2xl font-semibold mb-4">Personal Information</h2>
        <p class="text-gray-600 mb-6">Hi, I'm motoakitom. I'm a passionate developer and creator.</p>
        
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <i class="fas fa-map-marker-alt text-indigo-600"></i>
            <span>Location: Japan</span>
          </div>
          <div class="flex items-center gap-2">
            <i class="fas fa-birthday-cake text-indigo-600"></i>
            <span>Birthday: YYYY-MM-DD</span>
          </div>
          <div class="flex items-center gap-2">
            <i class="fas fa-envelope text-indigo-600"></i>
            <span>Email: motoxii@live.jp</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-16">
    <h2 class="text-2xl font-bold mb-8">Skills</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="text-xl font-semibold mb-2">Web Development</h3>
        <ul class="space-y-1">
          <li>JavaScript</li>
          <li>React</li>
          <li>Astro</li>
          <li>Node.js</li>
        </ul>
      </div>
      <div class="bg-white p-6 rounded-lg shadow">
        <h3 class="text-xl font-semibold mb-2">Design</h3>
        <ul class="space-y-1">
          <li>UI/UX Design</li>
          <li>Adobe XD</li>
          <li>Figma</li>
        </ul>
      </div>
    </div>
  </section>
</main>
